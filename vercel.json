{
    "version": 2,
    "framework": null,
    "builds": [
        {
            "src": "public/index.php",
            "use": "vercel-php@0.8.0"
        },
        {
            "src": "public/build/assets/**",
            "use": "@vercel/static"
        },
        {
            "src": "public/images/**",
            "use": "@vercel/static"
        },
        {
            "src": "public/js/**",
            "use": "@vercel/static"
        },
        {
            "src": "public/favicon.*",
            "use": "@vercel/static"
        }
    ],
    "routes": [
        {
            "src": "/build/(.*)",
            "dest": "/public/build/$1"
        },
        {
            "src": "/images/(.*)",
            "dest": "/public/images/$1"
        },
        {
            "src": "/js/(.*)",
            "dest": "/public/js/$1"
        },
        {
            "src": "/(.*)",
            "dest": "/public/index.php"
        }
    ],
    "env": {
        "APP_ENV": "production",
        "APP_DEBUG": "false",
        "LOG_CHANNEL": "stderr",
        "CACHE_STORE": "database",
        "SESSION_DRIVER": "database",
        "QUEUE_CONNECTION": "database",
        "DB_CONNECTION": "pgsql"
    }
}
